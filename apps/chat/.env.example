# ─── Slack App ────────────────────────────────────────────────────────────────
# From api.slack.com/apps > Basic Information > App Credentials
SLACK_CLIENT_ID=000000000000.000000000000
SLACK_CLIENT_SECRET=placeholder-client-secret
SLACK_SIGNING_SECRET=placeholder-signing-secret

# Generate with: openssl rand -base64 32
# Used to encrypt Slack bot tokens at rest in Redis (optional but recommended in production)
SLACK_ENCRYPTION_KEY=

# ─── Telegram (optional) ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_USERNAME=CalcomBot
# Optional: set in BotFather webhook secret; used to verify incoming webhook requests
# TELEGRAM_WEBHOOK_SECRET_TOKEN=
# Optional: self-hosted Telegram API gateway (default: https://api.telegram.org)
# TELEGRAM_API_BASE_URL=

# ─── Redis ────────────────────────────────────────────────────────────────────
# Upstash Redis (serverless) or any Redis-compatible URL
# Required for production. Omit for local dev (uses in-memory state adapter).
REDIS_URL=redis://localhost:6379
# For Upstash: REDIS_URL=rediss://default:TOKEN@HOST:PORT
# Optional: key prefix for Chat state adapter (default: chat-sdk). Changing this requires reinstalling the Slack app.
# REDIS_KEY_PREFIX=chat-sdk
# Optional: use ioredis adapter for Redis Cluster/Sentinel support.
# REDIS_USE_IOREDIS=true

# ─── Cal.com ──────────────────────────────────────────────────────────────────
CALCOM_API_URL=https://api.cal.com

# OAuth client credentials (from https://app.cal.com/settings/developer/oauth)
# Redirect URI to set when creating the OAuth client: ${NEXT_PUBLIC_APP_URL}/api/auth/calcom/callback
CALCOM_OAUTH_CLIENT_ID=your-calcom-oauth-client-id
CALCOM_OAUTH_CLIENT_SECRET=your-calcom-oauth-client-secret

# Webhook signing secret (set in Cal.com > Settings > Developer > Webhooks)
CALCOM_WEBHOOK_SECRET=your-calcom-webhook-secret

# Cal.com app URL for links
CALCOM_APP_URL=https://app.cal.com

# ─── AI / LLM (Vercel AI Gateway) ────────────────────────────────────────────
# Single API key for all AI models. Get yours at vercel.com/ai-gateway
AI_GATEWAY_API_KEY=your-ai-gateway-api-key
AI_MODEL=anthropic/claude-sonnet-4.6 | openai/gpt-4o | google/gemini-2.0-flash

# ─── App ──────────────────────────────────────────────────────────────────────
# Your deployed app URL (used for OAuth redirect URI and install page CTA)
NEXT_PUBLIC_APP_URL=https://chat.cal.com

# Optional: log level (debug | info | warn | error | silent). Default: info in prod, debug in dev.
# LOG_LEVEL=info

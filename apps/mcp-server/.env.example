# Auth mode: apikey | oauth | hosted
CAL_AUTH_MODE=apikey

# API key auth (CAL_AUTH_MODE=apikey)
CAL_API_KEY=cal_live_xxxx

# OAuth auth (CAL_AUTH_MODE=oauth, single-account / stdio mode)
CAL_OAUTH_CLIENT_ID=
CAL_OAUTH_CLIENT_SECRET=
CAL_OAUTH_ACCESS_TOKEN=        # optional seed
CAL_OAUTH_REFRESH_TOKEN=       # optional seed

# Hosted multi-tenant OAuth (CAL_AUTH_MODE=hosted)
# CAL_OAUTH_CLIENT_ID=           # also required for hosted
# CAL_OAUTH_CLIENT_SECRET=       # also required for hosted
# CAL_TOKEN_ENCRYPTION_KEY=      # 64 hex chars (32 bytes) for AES-256-GCM token encryption
# DATABASE_PATH=mcp-server.db    # SQLite database file path
# PORT=3100                      # HTTP server port for OAuth endpoints
# OAUTH_CALLBACK_URL=            # e.g. https://your-host.com (callback will be /oauth/callback)

# Optional
CAL_API_BASE_URL=https://api.cal.com

# ── stdio mode (local dev) ──
# API key (required for stdio mode)
CAL_API_KEY=cal_live_xxxx

# Optional: override the Cal.com API base URL
# CAL_API_BASE_URL=https://api.cal.com

# Transport mode: "stdio" (default) for local MCP clients, "http" for remote/production
# MCP_TRANSPORT=stdio

# HTTP server port (only used when MCP_TRANSPORT=http)
# PORT=3100

# ── HTTP mode (remote/production with OAuth 2.1) ──
# All of the following are required when MCP_TRANSPORT=http

# Cal.com OAuth application credentials (from https://app.cal.com/settings/developer/oauth-clients)
# CAL_OAUTH_CLIENT_ID=your_client_id
# CAL_OAUTH_CLIENT_SECRET=your_client_secret

# Public URL of this MCP server (used for OAuth redirect URIs)
# MCP_SERVER_URL=https://your-host.com

# 32-byte hex key (64 chars) for AES-256-GCM encryption of stored tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# TOKEN_ENCRYPTION_KEY=

# Optional: override the Cal.com app base URL (for authorize redirect)
# CAL_APP_BASE_URL=https://app.cal.com

# Postgres connection string (required for HTTP mode)
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Rate limiting for OAuth endpoints (token bucket per IP)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=30

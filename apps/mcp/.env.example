# Cal.com MCP Server Environment Variables
# Copy this file to .env and fill in the values

# Cal.com API v2 Base URL (default: https://api.cal.com)
API_BASE_URL=https://api.cal.com

# Cal.com API Key (required)
# Get your API key from https://app.cal.com/settings/developer/api-keys
# The key should be prefixed with cal_
CAL_API_KEY=cal_your_api_key_here

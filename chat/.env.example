# ─── Slack App ────────────────────────────────────────────────────────────────
# From api.slack.com/apps > Basic Information > App Credentials
SLACK_CLIENT_ID=000000000000.000000000000
SLACK_CLIENT_SECRET=placeholder-client-secret
SLACK_SIGNING_SECRET=placeholder-signing-secret

# Generate with: openssl rand -base64 32
# Used to encrypt Slack bot tokens at rest in Redis (optional but recommended in production)
SLACK_ENCRYPTION_KEY=

# ─── Redis ────────────────────────────────────────────────────────────────────
# Upstash Redis (serverless) or any Redis-compatible URL
REDIS_URL=redis://localhost:6379
# For Upstash: REDIS_URL=rediss://default:TOKEN@HOST:PORT

# ─── Cal.com ──────────────────────────────────────────────────────────────────
CALCOM_API_URL=https://api.cal.com

# OAuth client credentials (from https://app.cal.com/settings/developer/oauth)
# Redirect URI to set when creating the OAuth client: ${NEXT_PUBLIC_APP_URL}/api/auth/calcom/callback
CALCOM_OAUTH_CLIENT_ID=your-calcom-oauth-client-id
CALCOM_OAUTH_CLIENT_SECRET=your-calcom-oauth-client-secret

# Webhook signing secret (set in Cal.com > Settings > Developer > Webhooks)
CALCOM_WEBHOOK_SECRET=your-calcom-webhook-secret

# Cal.com app URL for links
CALCOM_APP_URL=https://app.cal.com

# ─── AI / LLM ────────────────────────────────────────────────────────────────
# Default: Groq (fast inference). Get your key at console.groq.com
GROQ_API_KEY=your-groq-api-key
# Model to use (optional, default: llama-3.3-70b-versatile)
# AI_MODEL=llama-3.3-70b-versatile
#
# To switch providers, edit lib/ai-provider.ts. Examples:
#   Anthropic: ANTHROPIC_API_KEY=sk-ant-...
#   OpenAI:    OPENAI_API_KEY=sk-...

# ─── App ──────────────────────────────────────────────────────────────────────
# Your deployed app URL (used for OAuth redirect URI and install page CTA)
NEXT_PUBLIC_APP_URL=https://your-domain.com
